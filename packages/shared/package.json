{
  "name": "@repo/shared",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./types": {
      "types": "./src/types/index.ts",
      "default": "./dist/types/index.js"
    },
    "./db": {
      "types": "./src/db/schema.ts",
      "default": "./dist/db/schema.js"
    },
    "./db/schemas": {
      "types": "./src/db/schemas.ts",
      "default": "./dist/db/schemas.js"
    },
    "./db/relations": {
      "types": "./src/db/relations.ts",
      "default": "./dist/db/relations.js"
    },
    "./constants": {
      "types": "./src/constants/index.ts",
      "default": "./dist/constants/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "lint": "eslint .",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "^0.8.3",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "eslint": "^9.0.0",
    "typescript": "^5.9.2"
  }
}
