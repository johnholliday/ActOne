// Invalid values fixture — triggers all validation rules
// Each violation is annotated with the expected error
story "Invalid Story" {

  // ── Duplicate generate blocks (only one allowed) ──────────────────
  generate {
    temperature: 0.5,
  }

  // Second generate block → error: "A story may contain at most one generate block."
  generate {
    temperature: 1.0,
  }

  // ── Out-of-range personality traits ───────────────────────────────
  character Alice {
    nature: Human,
    bio: "Test character for range violations.",
    personality: {
      // Valid boundary
      courage: 0,
      // Valid boundary
      kindness: 100,
      // Above maximum → error: "Personality trait value must be between 0 and 100"
      excessTrait: 101,
    },
    // Self-relationship → error: "Character 'Alice' cannot have a relationship with itself."
    relationships: [
      {
        to: Alice,
        weight: 50,
        label: "self",
      },
      // Out-of-range weight → error: "Relationship weight must be between -100 and +100"
      {
        to: Bob,
        weight: -101,
        label: "enemy",
      },
      // Out-of-range weight (above)
      {
        to: Bob,
        weight: 101,
        label: "too close",
      },
    ],
  }

  character Bob {
    nature: Human,
    bio: "Second test character.",
    personality: {
      resolve: 50,
    },
  }

  // ── Out-of-range generation settings ──────────────────────────────
  // Note: These are in the first generate block, but we test range separately

  // ── Out-of-range temperature (standalone test) ────────────────────
  // Covered by the generate blocks above; additional tests done in validator.test.ts

  // ── Out-of-range mood values ──────────────────────────────────────
  world BrokenWorld {
    locations: [
      {
        name: DarkPlace,
        description: "A location with invalid mood values.",
        atmosphere: {
          // Above maximum → error: "Mood value must be between 0 and 100"
          joy: 101,
          // Valid boundary
          calm: 0,
          // Valid boundary
          unease: 100,
        },
      },
    ],
  }

  // ── Scene with unresolved participant ─────────────────────────────
  scene BrokenScene {
    type: Action,
    location: DarkPlace,
    // UnknownCharacter is not defined → linking error
    participants: [Alice, UnknownCharacter],
    objective: "Test unresolved reference.",
  }

  // ── Interaction with out-of-range style_mix ───────────────────────
  interaction BrokenInteraction {
    participants: [Alice, Bob],
    pattern: "test",
    style_mix: {
      // Above maximum → error: "Style mix value must be between 0 and 100"
      Bob: 101,
    },
  }

}
