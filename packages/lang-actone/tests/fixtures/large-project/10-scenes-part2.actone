// Performance benchmark: scenes 51-100
story "The Grand Tapestry" {

  scene KhalidConfesses {
    type: Revelation,
    location: SunderPoint,
    participants: [Khalid, Lyra, Fen, Sable],
    objective: "Khalid reveals his full role in the original Sundering to the entire group.",
    transition: Dissolve,
  }

  scene RowanJoins {
    type: Dialogue,
    location: SilentForge,
    participants: [Rowan, Lyra],
    objective: "Rowan offers his Thread-cutting expertise to the group, naming his conditions.",
