  }

  scene RefugeeEvacuation {
    type: Action,
    location: RefugeeQuarter,
    participants: [Petra, Viktor, Callum],
    objective: "A sudden expansion of the Frayed Edges forces an emergency evacuation of the quarter.",
    transition: Smash,
  }

  scene DreamOfTheFirstWeaving {
    type: Reflection,
    location: LoomHeart,
    participants: [Lyra],
    objective: "Lyra experiences a vision of the original Weavers creating the Tapestry.",
