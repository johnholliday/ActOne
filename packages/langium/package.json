{
  "name": "@repo/langium",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./worker": {
      "types": "./src/worker/main-browser.ts",
      "default": "./dist/worker/main-browser.js"
    }
  },
  "scripts": {
    "build": "langium generate && tsc",
    "build:langium": "langium generate",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "langium": "~4.2.1",
    "vscode-languageserver": "~9.0.1",
    "vscode-languageserver-protocol": "~3.17.5"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "langium-cli": "~4.2.0",
    "eslint": "^9.0.0",
    "typescript": "^5.9.2",
    "vitest": "^3.2.1"
  }
}
