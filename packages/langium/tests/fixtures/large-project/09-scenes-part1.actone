// Performance benchmark: scenes 1-50
story "The Grand Tapestry" {

  scene TheUnraveling {
    type: Revelation,
    location: HighTower,
    participants: [Lyra],
    objective: "Lyra witnesses the first major tear in the Tapestry from the HighTower.",
    transition: Cut,
  }

  scene CallToAction {
    type: Dialogue,
    location: WeavingHall,
    participants: [Lyra, Khalid],
    objective: "Khalid reveals the scope of the crisis and asks Lyra to undertake the quest.",
    transition: Dissolve,
  }

  scene SmugglersGambit {
    type: Action,
    location: SmugglersCove,
    participants: [Fen, Mordecai],
    objective: "Fen attempts to steal Thread intelligence from Mordecai's smuggling operation.",
    transition: Cut,
  }

  scene OldWounds {
    type: Dialogue,
    location: WatchfireStation,
    participants: [Sable, Orin],
    objective: "Sable reunites with her former comrade and confronts memories of the Thread Wars.",
    transition: Dissolve,
  }

  scene TheRogueWeaver {
    type: Confrontation,
    location: ThreadArchive,
    participants: [Rowan, Esme],
    objective: "Rowan breaks into the ThreadArchive seeking forbidden knowledge, confronted by Esme.",
