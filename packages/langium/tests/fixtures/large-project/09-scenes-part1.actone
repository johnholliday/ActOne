  }

  scene CouncilDebate {
    type: Dialogue,
    location: CouncilChamber,
    participants: [Khalid, Priya, Katya],
    objective: "Khalid petitions the Council for resources while Priya mediates and Katya objects.",
    transition: Cut,
  }

  scene ThreadSong {
    type: Reflection,
    location: PatternGarden,
    participants: [Isolde, Wren],
