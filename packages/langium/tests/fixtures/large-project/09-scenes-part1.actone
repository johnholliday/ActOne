  }

  scene GatheringThreads {
    type: Montage,
    location: MarketNexus,
    participants: [Lyra, Fen, Sable],
    objective: "The three protagonists meet at the MarketNexus and begin assembling their team.",
    transition: Dissolve,
  }

  scene WhisperFromThePast {
    type: Revelation,
    location: ThreadArchive,
    participants: [Lyra, Whisper],
