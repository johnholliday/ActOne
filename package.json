{
  "name": "ActOne",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "start": "pnpm dev --filter=studio",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "test": "turbo run test",
    "check-types": "turbo run check-types",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:status": "supabase status",
    "db:reset": "supabase db reset",
    "db:migration:generate": "turbo run db:migration:generate --filter=studio",
    "db:migration:push": "turbo run db:migration:push --filter=studio",
    "clean": "turbo run clean && rm -rf node_modules/.cache",
    "clean:all": "turbo run clean && rm -rf node_modules **/node_modules .turbo **/.turbo **/dist **/.svelte-kit",
    "typecheck": "turbo run check-types",
    "format:check": "prettier --check \"**/*.{ts,tsx,md}\"",
    "preview": "turbo run preview --filter=studio",
    "studio": "turbo run dev --filter=studio"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "supabase": "^2.76.15",
    "turbo": "^2.8.10",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}