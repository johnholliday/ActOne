{
  "name": "ActOne",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "start": "pnpm dev --filter=studio",
    "start:fresh": "pnpm clean:all && pnpm install && pnpm build && pnpm start",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "test": "turbo run test",
    "test:ui": "pnpm --filter studio exec vitest --ui",
    "check-types": "turbo run check-types",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:status": "supabase status",
    "db:reset": "supabase db reset",
    "db:migration:generate": "turbo run db:migration:generate --filter=studio",
    "db:migration:push": "turbo run db:migration:push --filter=studio",
    "ports:sync": "node --experimental-strip-types --disable-warning=MODULE_TYPELESS_PACKAGE_JSON scripts/sync-ports.ts",
    "clean": "turbo run clean && rm -rf node_modules/.cache",
    "clean:all": "turbo run clean && rm -rf node_modules **/node_modules .turbo **/.turbo **/dist **/.svelte-kit",
    "typecheck": "turbo run check-types",
    "format:check": "prettier --check \"**/*.{ts,tsx,md}\"",
    "preview": "turbo run preview --filter=studio",
    "studio": "turbo run dev --filter=studio",
    "guide:dev": "pnpm --filter actone-guide dev",
    "guide:build": "pnpm --filter actone-guide build"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "prettier": "^3.7.4",
    "supabase": "^2.76.15",
    "turbo": "^2.8.16",
    "typescript": "5.9.2"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "@docugenix/sanyam-guide>vite": "7"
      }
    }
  },
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=18"
  }
}