# Supabase local development keys (from `pnpm db:start` / `pnpm db:status`)
PUBLIC_SUPABASE_URL=http://127.0.0.1:54521
PUBLIC_SUPABASE_ANON_KEY=<publishable key from supabase status>
SUPABASE_SERVICE_ROLE_KEY=<secret key from supabase status>
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54522/postgres
